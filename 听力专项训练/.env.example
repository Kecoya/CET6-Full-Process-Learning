# DeepSeek API 配置 —— 复制本文件为 .env 并填入你的密钥
# 获取密钥：https://platform.deepseek.com/
#
# ⚠️ .env 已被 .gitignore 忽略，绝不会上传到 GitHub。
#   请勿把真实密钥写进本文件(.env.example)，本文件仅作模板示范。

DEEPSEEK_API_KEY=sk-在此填入你的密钥

# —— 以下为可选项，留空即用 app.py 内置默认值 ——
# 覆盖默认模型
# DEEPSEEK_MODEL=deepseek-chat
# 服务监听端口（默认 5555）
# PORT=5555
# 服务监听地址（默认 127.0.0.1）
# HOST=127.0.0.1
# 启动时不自动打开浏览器（设为 1）
# NO_OPEN_BROWSER=1
